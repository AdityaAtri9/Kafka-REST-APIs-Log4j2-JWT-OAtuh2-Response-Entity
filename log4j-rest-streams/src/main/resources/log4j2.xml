<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN" monitorInterval="30">
	<Properties>
		<property name="LOG_PATH">C:/Practice/log4j-rest-streams/logs</property>
		<!--		<property name="LOG_PATH">Logs</property>
-->
		<property name="APP_NAME">logstream</property>
	</Properties>

	<Appenders>
		<Console name="Console" target="SYSTEM_OUT">
			<PatternLayout
				pattern="[%d{HH:mm:ss.SSS}] [%t] [%-5level] %c{1} - %msg%n" />
		</Console>

		<RollingFile name="File"
			filename="${LOG_PATH}/${APP_NAME}.log"
			filePattern="${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz"
			createOnDemand="true">
			<PatternLayout
				pattern="[%d{yyyy-MM-dd HH:mm:ss.SSS}] [%t] [%-5level] %c - %msg%n" />
			<Policies>
				<TimeBasedTriggeringPolicy interval="1" />
				<SizeBasedTriggeringPolicy size="10MB" />
			</Policies>
		</RollingFile>
	</Appenders>

	<Loggers>
		<Logger name="com.techtez.learning" level="debug" additivity="false">
			<AppenderRef ref="Console" />
			<AppenderRef ref="File" />
		</Logger>

		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="File" />
		</Root>
	</Loggers>
</Configuration>